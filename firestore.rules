rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Важно: read на чужие users — иначе поиск людей вернёт 0 результатов.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid;
    }

    match /duo_projects/{projectId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.creatorUid == request.auth.uid;
      // Создатель может редактировать/удалять проект целиком
      allow delete: if request.auth != null && resource.data.creatorUid == request.auth.uid;
      allow update: if request.auth != null && (
        // создатель может обновлять всё
        resource.data.creatorUid == request.auth.uid
        // участники могут только присоединяться (обновление массива members) и updatedAt
        || (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['members', 'updatedAt'])
          && request.auth.uid in request.resource.data.members
        )
      );
    }

    // Чат дуо-проекта: только участники (members)
    match /duo_projects/{projectId}/messages/{messageId} {
      allow read: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/duo_projects/$(projectId)).data.members;
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid
        && request.auth.uid in get(/databases/$(database)/documents/duo_projects/$(projectId)).data.members;
    }

    match /directChats/{chatId} {
      allow read, create, update: if request.auth != null;
    }

    match /directChats/{chatId}/messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid;
    }
  }
}
